# FastAPI metadata
API_TITLE=agent-ready-extract-api
API_DESCRIPTION=API REST para extracción legítima de contenido público (MVP).
API_VERSION=0.1.0

# Server / logging
LOG_LEVEL=INFO

# CORS
# Comma-separated list. Example: http://localhost:3000,http://127.0.0.1:3000
# Use "*" only for local/dev if you understand the implications.
CORS_ALLOW_ORIGINS=

# RapidAPI proxy protection
# If not set, POST /api/v1/extract is blocked (403) by design.
# Set this to a long random value and configure RapidAPI to send it in:
#   X-RapidAPI-Proxy-Secret: <same value>
RAPIDAPI_PROXY_SECRET=

